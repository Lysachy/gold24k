generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(uuid())
  name        String
  sku         String   @unique
  category    String
  material    String?
  purity      String?
  weight      Float?
  price       Float
  description String?
  imageUrl    String?
  status      String   @default("available")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
